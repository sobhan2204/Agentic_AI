{
  "tool_keywords": {
    "math_server": {
      "keywords": [
        "solve equation", "evaluate expression", "simplify expression",
        "factorize", "differentiate", "integration", "definite integral",
        "indefinite integral", "limit", "derivative of", "integral of",
        "quadratic formula", "matrix multiplication", "determinant",
        "vector dot product", "vector cross product", "probability",
        "combinatorics", "permutation", "combination", "log base",
        "trigonometric identity", "solve for x", "system of equations"
      ],
      "description": "Mathematical calculations and symbolic problem solving"
    },
    "weather": {
      "keywords": [
        "current weather", "weather forecast", "7-day forecast",
        "hourly forecast", "rain chance", "humidity level",
        "wind speed", "uv index", "feels like", "sunrise time",
        "sunset time", "air quality index", "aqi level",
        "temperature in", "storm alert", "weather alert"
      ],
      "description": "Weather conditions, forecasts, and air quality data"
    },
    "translate": {
      "keywords": [
        "translate to", "translate into", "translate this",
        "translate sentence", "translate paragraph",
        "how to say in", "what does it mean in",
        "english to", "hindi to", "spanish to", "french to",
        "german to", "arabic to", "japanese to", "korean to",
        "russian to", "portuguese to", "italian to", "urdu to"
      ],
      "description": "Language translation and phrase conversion"
    },
    "websearch": {
      "keywords": [
        "latest news on", "recent update on", "breaking news",
        "search web for", "find sources for", "official website of",
        "site:", "pdf report", "research paper", "journal article",
        "download pdf", "public report", "government portal",
        "news article", "press release", "fact check", "source link"
      ],
      "description": "Web search, source discovery, and document retrieval"
    },
    "gmail": {
      "keywords": [
        "send email", "compose email", "email to",
        "reply to email", "forward email", "draft email",
        "check inbox", "read emails", "unread emails",
        "latest email", "email subject", "email attachment",
        "gmail message", "inbox email", "mail thread"
      ],
      "description": "Gmail operations (send, read, reply, forward)"
    }
  },
  "priority_rules": {
    "exact_matches": [
      {
        "pattern": "translate .* to .*",
        "tool": "translate"
      },
      {
        "pattern": "what is .* weather",
        "tool": "weather"
      },
      {
        "pattern": "send email to .*",
        "tool": "gmail"
      },
      {
        "pattern": "search (for|about) .*",
        "tool": "websearch"
      }
    ]
  }
}